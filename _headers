# Assets are overwritten in place (no version hash), so they must revalidate —
# otherwise browsers/CDN keep stale CSS/JS/images and updates don't show.
/assets/*
  Cache-Control: public, max-age=0, must-revalidate

/favicon.ico
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate
